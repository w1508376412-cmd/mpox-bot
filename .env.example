# 对话模型配置（OpenAI SDK 兼容接口；可指向 DeepSeek 等服务）
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=deepseek-v4-flash
OPENAI_API_BASE=https://api.deepseek.com

# 阿里百炼配置（用于向量生成）
ALIBABA_API_KEY=your_alibaba_api_key_here
ALIBABA_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_MODEL=text-embedding-v4

# 数据库配置
DATABASE_URL=postgresql://postgres:password@localhost:5432/mpox_bot

# 服务配置
HOST=0.0.0.0
PORT=8000
DEBUG=true

# 默认地区
DEFAULT_REGION=中国
